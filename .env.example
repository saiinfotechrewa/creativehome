# ---------------------------------------------------------------------------
# CreativeDox — environment variables
# Copy to `.env.local` for local dev, or set these in Coolify's env panel.
# `.env*` files are gitignored; only this example is committed.
# ---------------------------------------------------------------------------

# --- Required ---------------------------------------------------------------

# Public, canonical site origin (no trailing slash). Used to build absolute
# URLs for metadata, sitemap.xml, robots.txt, OG tags, and JSON-LD.
# Local: http://localhost:3000   Production: your real domain.
NEXT_PUBLIC_SITE_URL=https://creativedox.com

# --- Runtime (set automatically by Docker/Coolify; override if needed) ------

# Port the Next.js server listens on inside the container.
PORT=3000
# Bind address — 0.0.0.0 so the container is reachable from the host/proxy.
HOSTNAME=0.0.0.0
NODE_ENV=production

# --- Optional integrations (uncomment + fill in when wired up) --------------
# These are NOT referenced in the code yet — placeholders for future work.

# Analytics (e.g. Plausible / GA / Umami)
# NEXT_PUBLIC_ANALYTICS_DOMAIN=creativedox.com
# NEXT_PUBLIC_GA_ID=

# Lead/contact form delivery endpoint or provider key
# CONTACT_FORM_ENDPOINT=
# RESEND_API_KEY=

# Newsletter provider
# NEWSLETTER_API_KEY=
